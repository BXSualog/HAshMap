      },
      "package": "com.bxfiles.alistoai",
      "softwareKeyboardLayoutMode": "adjustResize"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "d2de439f-c9f4-44f2-9b0a-bd4b4dc2cf56"
