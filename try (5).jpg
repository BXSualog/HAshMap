<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Alisto</title>
    <link rel="stylesheet" href="style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Cinzel:wght@400..900&family=Domine:wght@400..700&family=Oswald:wght@200..700&family=Zilla+Slab:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&display=swap"
        rel="stylesheet">
</head>

<body>
    <div class="slogan-bar" id="sloganBar">
        <span class="slogan-brand">ALISTO</span>
        <span class="slogan-divider">-</span>
        <span class="slogan-tagline">ISA, DALAWA, TATLO - PANALO!</span>
    </div>
    <header>
        <i class="fa-brands fa-ns8" id="logo"></i>
        <nav>
            <ul>
                <li><a href="../WelcomeInterFace.html" style="text-decoration:none;"><button>Home</button></a></li>
                <li class="has-dropdown">
                    <button class="dropdown-toggle">
                        Info
                        <i class="fa-solid fa-chevron-down dropdown-chevron"></i>
                    </button>
                    <div class="dropdown-menu">
                        <a href="pages/disasters.html" class="dropdown-item">
                            <span class="dropdown-item-icon"><i class="fa-solid fa-house-tsunami"></i></span>
                            <span class="dropdown-item-text">
                                <span class="dropdown-item-title">Disasters</span>
                                <span class="dropdown-item-desc">Types &amp; historical events</span>
                            </span>
                        </a>
                        <a href="pages/preparedness.html" class="dropdown-item">
                            <span class="dropdown-item-icon"><i class="fa-solid fa-shield-halved"></i></span>
                            <span class="dropdown-item-text">
                                <span class="dropdown-item-title">Preparedness</span>
                                <span class="dropdown-item-desc">Kits, plans &amp; early action</span>
                            </span>
                        </a>
                        <a href="pages/recovery.html" class="dropdown-item">
                            <span class="dropdown-item-icon"><i class="fa-solid fa-rotate-right"></i></span>
                            <span class="dropdown-item-text">
                                <span class="dropdown-item-title">Recovery</span>
                                <span class="dropdown-item-desc">Rebuilding after a disaster</span>
                            </span>
                        </a>
                    </div>
                </li>
                <li><button>Contacts</button></li>
                <li><button>About</button></li>
            </ul>
        </nav>
    </header>
    <section class="MeetingHeader">
        <h1>ALIS<span>TO</span></h1>
        <h2>Buhay Ingatan, Para sa Masaganang <span class="highlight">Kinabukasan</span>.</h2>
    </section>
    <section class="sub">
        <div class="subs">
            <h3>Average of<br>20</h3>
            <p>Typhoons per year</p>
        </div>
        <div class="subs">
            <h3>₱85 Billion</h3>
            <p>Annually in direct losses to public<br>and private assets</p>
        </div>
        <div class="subs">
            <h3>1000+</h3>
            <p>Average death caused by<br>Disasters per year</p>
        </div>
    </section>
    <script src="main.js"></script>
</body>

</html>
